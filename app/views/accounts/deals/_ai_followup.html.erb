<div id="ai-followup-<%= deal.id %>" data-controller="load-lucid-icons">
  <div class="bg-light-palette-p5 border-2 border-brand-palette-06 rounded-lg overflow-hidden">
    <!-- Header -->
    <div class="flex items-center justify-between px-4 py-3 border-b-2 border-brand-palette-06">
      <div class="flex items-center gap-2">
        <i data-lucide="brain-circuit" class="w-5 h-5 text-brand-palette-03"></i>
        <h3 class="typography-sub-title-800 text-dark-palette-p1"><%= t('views.accounts.deals.ai_followup.title') %></h3>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-brand-palette-03 text-white"><%= t('views.accounts.deals.ai_followup.new_badge') %></span>
      </div>
      <div class="flex items-center gap-2">
        <span class="typography-body-800 text-dark-gray-palette-p3 text-xs">
          <%= deal.custom_attributes.fetch('ai_followup_enabled', false) ? t('views.accounts.deals.ai_followup.status_active') : t('views.accounts.deals.ai_followup.status_inactive') %>
        </span>
        <%= form_with url: toggle_ai_followup_account_deal_path(current_user.account, deal), method: :patch do |f| %>
          <button type="submit" class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors cursor-pointer focus:outline-none <%= deal.custom_attributes.fetch('ai_followup_enabled', false) ? 'bg-brand-palette-03' : 'bg-light-palette-p1' %>">
            <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform shadow <%= deal.custom_attributes.fetch('ai_followup_enabled', false) ? 'translate-x-6' : 'translate-x-1' %>"></span>
          </button>
        <% end %>
      </div>
    </div>

    <!-- Description -->
    <div class="px-4 py-3 border-b-2 border-brand-palette-06 bg-brand-palette-08">
      <p class="typography-body-800 text-dark-gray-palette-p2 text-xs">
        <%= deal.custom_attributes.fetch('ai_followup_enabled', false) ? t('views.accounts.deals.ai_followup.description_enabled') : t('views.accounts.deals.ai_followup.description_disabled') %>
      </p>
    </div>

    <!-- Follow-up messages timeline -->
    <div class="px-4 py-3 space-y-3">
      <% followup_events = deal.contact.events.where(deal: deal).where("additional_attributes ->> 'ai_generated' = 'true'").where(done_at: nil).order(:scheduled_at) %>
      <% if deal.custom_attributes.fetch('ai_followup_enabled', false) && followup_events.any? %>
        <% followup_events.each_with_index do |event, i| %>
          <% days = ((event.scheduled_at - Time.current) / 1.day).ceil rescue 0 %>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-brand-palette-07 border border-brand-palette-06">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brand-palette-06 border border-brand-palette-05 flex items-center justify-center">
              <i data-lucide="clock" class="w-4 h-4 text-brand-palette-03"></i>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="typography-body-800 text-xs font-semibold text-brand-palette-03">
                  <%= days > 0 ? t('views.accounts.deals.ai_followup.days_from_now', count: days) : t('views.accounts.deals.ai_followup.today') %>
                </span>
                <span class="typography-body-800 text-xs text-dark-gray-palette-p3">
                  · <%= l(event.scheduled_at, format: :short) rescue event.scheduled_at.strftime('%d/%m %H:%M') %>
                </span>
              </div>
              <p class="typography-body-800 text-xs text-dark-gray-palette-p1 line-clamp-2">
                <%= event.title %>
              </p>
            </div>
          </div>
        <% end %>
      <% else %>
        <!-- Template preview (when disabled) -->
        <% [3, 7, 14].each do |days| %>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-light-palette-p3 border border-light-palette-p2 opacity-60">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-light-palette-p2 border border-light-palette-p1 flex items-center justify-center">
              <i data-lucide="clock" class="w-4 h-4 text-dark-gray-palette-p4"></i>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="typography-body-800 text-xs font-semibold text-dark-gray-palette-p2">
                  <%= t('views.accounts.deals.ai_followup.days_preview', days: days) %>
                </span>
              </div>
              <p class="typography-body-800 text-xs text-dark-gray-palette-p4">
                <%= t('views.accounts.deals.ai_followup.preview_placeholder') %>
              </p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
