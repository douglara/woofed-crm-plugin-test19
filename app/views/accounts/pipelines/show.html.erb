<%= turbo_stream_from @pipeline %>
<%= turbo_frame_tag :stages do %>
  <div data-controller="lists" data-lists-id="<%= @pipeline.id %>">
    <section class="p-8 grid grid-flow-col auto-cols-[18.75rem] h-auto gap-5" data-lists-target="lists">
      <% @pipeline.stages.sort_by(&:position).each do |stage| %>
        <%= turbo_frame_tag stage, src: account_stage_path(current_user.account, stage, filter_status_deal: @filter_status_deal), refresh: :morph, data: { controller: "frame", action: "turbo:before-frame-render->frame#morphRender turbo:before-morph-element->frame#morphReload" }, loading: :lazy do %>
          <%= render '/components/skeleton/stage'%>
        <% end %>
      <% end %>
    </section>
  </div>
<% end %>
