Plugins::FilePatch.define target: "app/views/layouts/shared/_sidebar.html.erb" do
  # Add AI Follow-ups item after the reports item (anchor on the unique link_data line)
  replace_line containing: 'link_data: { controller: "form--set-timezone-offset" }',
               with: "    link_data: { controller: \"form--set-timezone-offset\" }\n  },\n  {\n    path: account_ai_followups_path(Current.account),\n    icon: 'brain-circuit',\n    label: t('plugins.ai_features.sidebar_label'),\n    active_if: -> { request.path.include?('ai_followup') },\n    new_feature: true"

  # Add flex-1 truncate to the menu item label span (10-space indent version inside the loop)
  replace_line containing: '          <span class="group-aria-[expanded=false]:hidden inline-block">',
               with: '          <span class="group-aria-[expanded=false]:hidden inline-block flex-1 truncate">'

  # Add new_feature badge after the label span closing tag (unique 10-space indent </span>)
  replace_line containing: "          </span>",
               with: "          </span>\n          <% if item[:new_feature] %>\n            <span class=\"group-aria-[expanded=false]:hidden inline-flex items-center px-1 py-0.5 rounded text-[9px] font-bold bg-purple-600 text-white leading-none ml-auto shrink-0\">NEW</span>\n          <% end %>"
end
