Plugins::FilePatch.define target: "app/views/layouts/shared/_sidebar.html.erb" do
  replace_line containing: "path: account_products_path(Current.account)",
               with: "    path: account_favorite_contacts_path(Current.account),\n" \
                     "    icon: 'star',\n" \
                     "    label: t('plugins.favorite_contacts.favorites'),\n" \
                     "    active_if: -> { request.path.include?('favorite_contacts') }\n" \
                     "  },\n" \
                     "  {\n" \
                     "    path: account_products_path(Current.account),"
end
