<div class="bg-light-palette-p5 border-2 border-neutral-150 border-light-palette-p3 rounded m-8">
  <header class="border-b-2 border-neutral-100 flex items-center justify-between gap-2 p-4 sticky top-0 bg-light-palette-p5 z-20">
    <div class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
      <h1 class="typography-title-b-lh150 text-dark-gray-palette-p1">
        <%= t('plugins.favorite_contacts.favorites') %>
      </h1>
    </div>
  </header>
  <% if @favorite_contacts.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-left rtl:text-right">
        <thead class="border-b border-light-palette-p3">
          <tr>
            <th scope="col" class="py-3 pl-4 pr-4 w-[52px]"></th>
            <th scope="col" class="pr-4 py-3 typography-body-s-lh150 text-dark-gray-palette-p1 max-w-[200px]">
              <%= t('activerecord.attributes.contact.full_name') %>
            </th>
            <th scope="col" class="pr-4 py-3 typography-body-s-lh150 text-dark-gray-palette-p1 max-w-[120px]">
              <%= t('activerecord.attributes.contact.phone') %>
            </th>
            <th scope="col" class="pr-4 py-3 typography-body-s-lh150 text-dark-gray-palette-p1 max-w-[200px]">
              <%= t('activerecord.attributes.contact.email') %>
            </th>
            <th scope="col" class="pr-4 py-3 typography-body-s-lh150 text-dark-gray-palette-p1 max-w-[150px]">
              <%= t('plugins.favorite_contacts.favorited_at') %>
            </th>
            <th scope="col" class="py-3 pl-4 pr-4 sticky right-0 bg-light-palette-p5 z-10 w-[80px]"></th>
          </tr>
        </thead>
        <tbody class="w-full">
          <% @favorite_contacts.each do |favorite| %>
            <% contact = favorite.contact %>
            <tr id="<%= dom_id(contact, :favorite_row) %>" class="border-b-2 border-light-palette-p3 last:border-none">
              <td class="py-2.5 pl-4 pr-4 flex-shrink-0">
                <div class="w-[52px] h-[52px] flex">
                  <div class="border-2 color-border-default bg-brand-palette-08 rounded-md h-full w-full flex items-center">
                    <i data-lucide="user" class="stroke-dark-gray-palette-p4 m-auto"></i>
                  </div>
                </div>
              </td>
              <td class="pr-4 py-2.5 typography-body-r-lh150 text-dark-gray-palette-p2 max-w-[200px] truncate">
                <%= link_to contact.full_name, account_contact_path(Current.account, contact),
                    class: "hover:text-dark-gray-palette-p1 hover:underline",
                    data: { turbo_frame: :drawer } %>
              </td>
              <td class="pr-4 py-2.5 typography-body-r-lh150 text-dark-gray-palette-p2 max-w-[120px] truncate">
                <%= contact.phone %>
              </td>
              <td class="pr-4 py-2.5 typography-body-r-lh150 text-dark-gray-palette-p2 max-w-[200px] truncate">
                <%= contact.email %>
              </td>
              <td class="pr-4 py-2.5 typography-body-r-lh150 text-dark-gray-palette-p2 max-w-[150px] truncate">
                <%= render "components/formatters/datetime", value: favorite.created_at, type: "compact" %>
              </td>
              <td class="py-2.5 pl-4 pr-4 sticky right-0 bg-light-palette-p5 z-10">
                <div class="flex justify-end gap-2">
                  <%= render 'accounts/favorite_contacts/favorite_button', contact: contact %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="sticky bottom-0 bg-light-palette-p5 z-10 py-2 px-4 border-t-2 border-light-palette-p3">
      <div class="flex justify-end">
        <%== pagy_nav(@pagy) %>
      </div>
    </div>
  <% else %>
    <div class="flex flex-col items-center justify-center py-16 px-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300 mb-4">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
      <p class="typography-body-r-lh150 text-dark-gray-palette-p3 text-center">
        <%= t('plugins.favorite_contacts.no_favorites') %>
      </p>
      <p class="typography-body-s-lh150 text-dark-gray-palette-p4 text-center mt-1">
        <%= t('plugins.favorite_contacts.no_favorites_hint') %>
      </p>
    </div>
  <% end %>
</div>
